        pbStroke.Color = Color3.fromRGB(0, 180, 255) -- Bright ocean blue border
        pbStroke.Thickness = 2
        
        -- Make draggable
        local _pbDragging, _pbDragStart, _pbStartPos = false, nil, nil
        pbFrame.InputBegan:Connect(function(inp)
            if inp.UserInputType == Enum.UserInputType.MouseButton1 or inp.UserInputType == Enum.UserInputType.Touch then
                _pbDragging = true
                _pbDragStart = inp.Position
                _pbStartPos = pbFrame.Position
                inp.Changed:Connect(function()
                    if inp.UserInputState == Enum.UserInputState.End then _pbDragging = false end
                end)
            end
        end)
        
        UserInputService.InputChanged:Connect(function(inp)
            if not _pbDragging then return end
            if inp.UserInputType == Enum.UserInputType.MouseMovement or inp.UserInputType == Enum.UserInputType.Touch then
                local delta = inp.Position - _pbDragStart
                pbFrame.Position = UDim2.new(
                    _pbStartPos.X.Scale, _pbStartPos.X.Offset + delta.X,
                    _pbStartPos.Y.Scale, _pbStartPos.Y.Offset + delta.Y
                )
            end
        end)
        
        -- Percentage text
        progressPct = Instance.new("TextLabel", pbFrame)
        progressPct.Size = UDim2.new(1, -30, 0, 22)
        progressPct.Position = UDim2.new(0, 15, 0, 8)
