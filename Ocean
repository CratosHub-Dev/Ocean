        progressRadLbl.Position = UDim2.new(1, -155, 0, 8)
        progressRadLbl.BackgroundTransparency = 1
        progressRadLbl.Text = "🌊 Radius: " .. stealRadius
        progressRadLbl.TextColor3 = Color3.fromRGB(100, 220, 255) -- Light ocean blue
        progressRadLbl.Font = Enum.Font.GothamBold
        progressRadLbl.TextSize = 15
        progressRadLbl.TextXAlignment = Enum.TextXAlignment.Right
        progressRadLbl.ZIndex = 5
        
        -- Progress bar background
        local pbBg = Instance.new("Frame", pbFrame)
        pbBg.Size = UDim2.new(1, -30, 0, 10)
        pbBg.Position = UDim2.new(0, 15, 0, 34)
        pbBg.BackgroundColor3 = Color3.fromRGB(3, 10, 30) -- Very dark ocean
        pbBg.BorderSizePixel = 0
        Instance.new("UICorner", pbBg).CornerRadius = UDim.new(0, 6)
        
        local bgStroke = Instance.new("UIStroke", pbBg)
        bgStroke.Color = Color3.fromRGB(0, 180, 255)
        bgStroke.Thickness = 1
        
        -- Progress fill (ocean gradient)
        progressFill = Instance.new("Frame", pbBg)
        progressFill.Size = UDim2.new(0, 0, 1, 0)
