    -- ============================================================
    -- APPLY WHITE CLOUDY SKY WITH RAIN
    -- ============================================================
    local rainGui = nil
    local rainDrops = {}
    local rainActive = false
    local rainAnimConn = nil

    local function stopRain()
        rainActive = false
        if rainAnimConn then
            rainAnimConn:Disconnect()
            rainAnimConn = nil
        end
        if rainGui and rainGui.Parent then
            rainGui:Destroy()
            rainGui = nil
        end
        rainDrops = {}
    end

    local function startRain()
        if rainActive then return end
        rainActive = true
        
        rainGui = Instance.new("ScreenGui")
        rainGui.Name = "RainEffect"
        rainGui.ResetOnSpawn = false
        rainGui.IgnoreGuiInset = true
        rainGui.ZIndexBehavior = Enum.ZIndexBehavior.Sibling
        rainGui.Parent = LP:WaitForChild("PlayerGui")
        
        local rainContainer = Instance.new("Frame", rainGui)
        rainContainer.Size = UDim2.new(1, 0, 1, 0)
        rainContainer.BackgroundTransparency = 1
        rainContainer.BorderSizePixel = 0
        
        rainDrops = {}
        for i = 1, 200 do
            local drop = Instance.new("Frame", rainContainer)
            local width = math.random(1, 2)
            local height = math.random(8, 18)
            drop.Size = UDim2.new(0, width, 0, height)
            drop.Position = UDim2.new(math.random() * 0.95, 0, math.random() * 1.2, 0)
            drop.BackgroundColor3 = Color3.fromRGB(100, 150, 255)
            drop.BackgroundTransparency = 0.3 + math.random() * 0.3
            drop.BorderSizePixel = 0
            drop.Rotation = 10 + math.random() * 10
            
            rainDrops[i] = {
                drop = drop,
                speed = 1.5 + math.random() * 2.5,
                length = height,
                startY = drop.Position.Y.Scale
            }
        end
        
        if rainAnimConn then rainAnimConn:Disconnect() end
        rainAnimConn = RunService.Heartbeat:Connect(function()
            if not rainActive or not rainGui or not rainGui.Parent then
                if rainAnimConn then rainAnimConn:Disconnect(); rainAnimConn = nil end
                return
            end
            for _, rd in ipairs(rainDrops) do
                if rd and rd.drop and rd.drop.Parent then
                    local newY = rd.drop.Position.Y.Scale + (rd.speed * 0.012)
                    if newY > 1.2 then
                        newY = -0.2
                        rd.drop.Position = UDim2.new(math.random() * 0.95, 0, newY, 0)
                    else
                        rd.drop.Position = UDim2.new(rd.drop.Position.X.Scale, 0, newY, 0)
                    end
                end
            end
        end)
    end

