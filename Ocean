        glow.Size = UDim2.new(1, 0, 1, 0)
        glow.BackgroundColor3 = Color3.fromRGB(50, 200, 255)
        glow.BackgroundTransparency = 0.7
        glow.BorderSizePixel = 0
        glow.ZIndex = 0
