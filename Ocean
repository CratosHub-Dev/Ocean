        stopRain()
        print("[ocean duels] Cloudy sky and rain removed!")
    end

    applyCloudySkyWithRain()

    -- ============================================================
    -- OCEAN DUELS PROGRESS BAR (Blue Edition)
    -- ============================================================

    local progressPct = nil
    local progressFill = nil
    local progressRadLbl = nil
    local progressBarFrame = nil
    local isStealing = false
    local stealStartTime = nil
    local stealDuration = 1.3
    local stealRadius = 20
    local progressConnection = nil

    local function createProgressBar()
        -- Destroy old if exists
        local oldGui = LP.PlayerGui:FindFirstChild("OceanProgressBar")
        if oldGui then oldGui:Destroy() end
        
