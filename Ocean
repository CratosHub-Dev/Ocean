        _pbGui.Name = "OceanProgressBar"
        _pbGui.ResetOnSpawn = false
        _pbGui.DisplayOrder = 20
        _pbGui.IgnoreGuiInset = true
        _pbGui.Parent = LP:WaitForChild("PlayerGui")
        
        local pbFrame = Instance.new("Frame", _pbGui)
        pbFrame.Size = UDim2.new(0, 320, 0, 52)
        pbFrame.Position = UDim2.new(0.5, -160, 1, -68)
        pbFrame.BackgroundColor3 = Color3.fromRGB(8, 20, 45) -- Deep ocean blue
        pbFrame.BorderSizePixel = 0
        pbFrame.Active = true
        progressBarFrame = pbFrame
        
        Instance.new("UICorner", pbFrame).CornerRadius = UDim.new(0, 12)
        
