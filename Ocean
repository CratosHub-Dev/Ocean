    end

    local function removeCloudySky()
        for _, child in ipairs(Lighting:GetChildren()) do
            if child:IsA("ColorCorrectionEffect") or child:IsA("Sky") then
                child:Destroy()
            end
        end
        
        Lighting.Ambient = Color3.fromRGB(127, 127, 127)
